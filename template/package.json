{
  "name": "moonquake",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:simulator": "react-native run-ios --simulator='iPhone 17 Pro Max'",
    "start": "react-native start",
    "install-pods": "cd ios && bundle exec pod install && cd ..",
    "pod-install": "bundle check || bundle install && cd ios && LANG=en_US.UTF-8 bundle exec pod install && cd ..",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "test:unit": "jest --config jest.unit.config.js --watchman=false",
    "madge": "npx madge -c --ts-config tsconfig.json --extensions tsx --warning .",
    "madge:image": "npx madge -c --ts-config tsconfig.json --extensions tsx --warning --image graph.svg .",
    "depcheck": "npx depcheck",
    "check-updates": "npx npm-check-updates",
    "sanity": "yarn lint; yarn tsc; yarn madge",
    "sanity:fix": "yarn lint --fix; yarn tsc; yarn madge",
    "get-bootsplash": "yarn react-native-bootsplash generate src/assets/logo.png --platforms=android,ios --background=E9E6FB --logo-width=192 --assets-output=src/assets/bootsplash --plist=ios/Moonquake/Info.plist"
  },
  "dependencies": {
    "@react-native/normalize-colors": "^0.86.0",
    "@react-navigation/elements": "^2.8.2",
    "@react-navigation/native": "7.1.20",
    "@react-navigation/native-stack": "7.6.3",
    "@reduxjs/toolkit": "^2.12.0",
    "i18next": "^25.7.4",
    "react": "19.2.3",
    "react-i18next": "^16.5.3",
    "react-native": "0.86.0",
    "react-native-bootsplash": "^7.3.2",
    "react-native-device-info": "15.0.1",
    "react-native-gesture-handler": "3.0.2",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-indicators": "0.17.0",
    "react-native-keyboard-controller": "^1.20.7",
    "react-native-mmkv": "^4.3.1",
    "react-native-modal": "13.0.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-reanimated": "^4.4.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.18.0",
    "react-native-svg": "^15.15.5",
    "react-native-unistyles": "^3.0.24",
    "react-native-worklets": "~0.10.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "7.19.1",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-export-namespace-from": "7.14.5",
    "@babel/plugin-transform-classes": "7.20.2",
    "@babel/plugin-transform-flow-strip-types": "7.19.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/eslintrc": "^2.1.4",
    "@ltatarev/eslint-config-react": "2.4.1",
    "@ltatarev/eslint-config-react-native": "2.4.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "4.1.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-react-native-a11y": "^3.4.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.0.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-preset": "0.76.7",
    "prettier": "^3.3.3",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "@react-native/jest-preset"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "packageManager": "yarn@4.17.0"
}
