{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"],
  "compilerOptions": {
    "types": ["jest"],
    "strict": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "assets": ["src/assets"],
      "assets/*": ["src/assets/*"],
      "common": ["src/common"],
      "common/*": ["src/common/*"],
      "modules": ["src/modules"],
      "modules/*": ["src/modules/*"],
      "theme": ["src/theme"],
      "theme/*": ["src/theme/*"],
      "utils": ["src/utils"],
      "utils/*": ["src/utils/*"]
    }
  }
}
