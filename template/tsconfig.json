{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"],
  "compilerOptions": {
    "rootDir": "./src",
    "types": ["jest"],
    "paths": {
      "modules/*": ["./modules/*"],
      "ui/*": ["./ui/*"],
      "utils/*": ["./utils/*"],
      "theme/*": ["./theme/*"],
      "assets/*": ["./assets/*"]
    }
  }
}
