{
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "overrides": [
    {
      "files": "*.js",
      "options": {
        "trailingComma": "all",
        "singleQuote": true,
        "arrowParens": "avoid"
      }
    }
  ]
}
